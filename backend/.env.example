# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/tick_management
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tick_management
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# Email (Ethereal/Mailtrap for dev)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass
EMAIL_FROM=noreply@ticketmanagement.com

# Frontend URL
FRONTEND_URL=http://localhost:3000
